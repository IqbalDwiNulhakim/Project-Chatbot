# ────────────────────────────────────────
#  AI Chatbot — Konfigurasi API Keys
#  Salin file ini menjadi .env dan isi sesuai provider yang digunakan
# ────────────────────────────────────────

PORT=3001

# Google Gemini (GRATIS dengan quota terbatas)
# Daftar di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (Berbayar)
# Daftar di: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (Murah / berbayar)
# Daftar di: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Ollama (GRATIS, berjalan lokal)
# Install: https://ollama.ai
# Jalankan: ollama run llama3
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
