# ────────────────────────────────────────
#  AI Chatbot — Konfigurasi
# ────────────────────────────────────────

PORT=3001

# Ollama (Local - GRATIS & Tanpa Batas)
# Install Ollama: https://ollama.ai
# Download model: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Optional: Provider lain (isi jika ingin menggunakan)
# GEMINI_API_KEY=...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...